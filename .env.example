# Copy this file to .env and adjust as needed.
# Values shown here match the defaults in docker-compose.yml.

# Postgres connection string used by SQLAlchemy's async engine.
# When running via docker-compose, host is the service name "db".
# When running locally against a Postgres you started yourself, use "localhost".
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/starwars

# Base URL for the external Star Wars API this service syncs from.
SWAPI_BASE_URL=https://swapi.dev/api

# Timeout (seconds) for each SWAPI request, before tenacity's retry/backoff kicks in.
SWAPI_TIMEOUT_SECONDS=10
